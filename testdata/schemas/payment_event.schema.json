{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["payment_id", "order_id", "amount"],
  "properties": {
    "payment_id": {
      "type": "string"
    },
    "order_id": {
      "type": "string"
    },
    "method": {
      "type": "string",
      "enum": ["credit_card", "debit_card", "paypal", "bank_transfer"]
    },
    "amount": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
